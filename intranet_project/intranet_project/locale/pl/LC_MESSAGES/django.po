#: notifier/receivers.py:722 notifier/receivers.py:732
msgid "Remote work updated"
msgstr "Praca zdalna - aktualizacja"

#: notifier/receivers.py:723
msgid "Remote work accepted by you was updated and waits for your reapproval."
msgstr ""
"Praca zdalna zaakceptowana przez Ciebie została zmodyfikowana i oczekuje na "
"Twoją decyzję."

#: notifier/receivers.py:733
msgid ""
"Remote work has been updated and now waits for reapproval from decisive "
"person."
msgstr ""
"Praca zdalna została zaktualizowana i teraz oczekuje na podjęcie decyzji "
"przez osobę decydującą."

#: notifier/receivers.py:741
msgid "Remote work decisive person changed"
msgstr "Praca zdalna - zmiana osoby decydującej"

#: notifier/receivers.py:742
msgid ""
"The decisive person in the remote work you were responsible for has changed. "
"You are no longer responsible for this remote work."
msgstr ""
"We wniosku o pracę zdalną została zmieniona osoba decydująca. Nie ponosisz "
"już odpowiedzialności za podjęcie decyzji dotyczącej tego wniosku."

#: notifier/receivers.py:750 notifier/receivers.py:760
msgid "Remote work canceled"
msgstr "Praca zdalna odwołana"

#: notifier/receivers.py:751
msgid "Cancelation of your remote work was accepted."
msgstr "Prośba o odwołanie Twojej pracy zdalnej została zaakceptowana."

#: notifier/receivers.py:761
msgid "One of remote works has been canceled."
msgstr "Jeden z wniosków o pracę zdalną został odwołany."

#: notifier/receivers.py:768 notifier/receivers.py:778
msgid "Remote work cancelation rejected"
msgstr "Prośba o odwołanie pracy zdalnej została odrzucona."

#: notifier/receivers.py:769
msgid "Cancelation of your remote work was rejected."
msgstr "Prośba o odwołanie Twojej pracy zdalnej została odrzucona."

#: notifier/receivers.py:779
msgid "One of remote works cancelation has been rejected."
msgstr ""
"Prośba o odwołanie jednego z wniosków o pracę zdalną została odrzucona."

#: notifier/receivers.py:786 notifier/receivers.py:804
#: notifier/receivers.py:814
msgid "Remote work decision changed"
msgstr "Praca zdalna - zmiana decyzji"

#: notifier/receivers.py:787
msgid "The decision regarding your remote work was changed to accepted."
msgstr ""
"Decyzja dotycząca Twojego wniosku o pracę zdalną została zmieniona na "
"zaakceptowany."

#: notifier/receivers.py:805
msgid "The decision regarding your remote work was changed to rejected."
msgstr ""
"Decyzja dotycząca Twojego wniosku o prace zdalną została zmieniona na "
"odrzucony."

#: notifier/receivers.py:815
msgid ""
"Remote work that previously was accepted, has been rejected by decisive."
msgstr ""
"Wniosek o pracę zdalną, który wcześniej był zaakceptowany, został odrzucony "
"przez osobę decydującą."

#: notifier/receivers.py:823
msgid "Remote work is pending to cancel"
msgstr "Prośba o odwołanie pracy zdalnej oczekuje na decyzję"

#: notifier/receivers.py:824
msgid "One of remote works you accepted is pending to cancel."
msgstr ""
"Jeden z wniosków o pracę zdalną, które były zaakceptowane, oczekuje na "
"decyzję w sprawie odwołania."

#: notifier/receivers.py:833
msgid "Remote work pending to cancel"
msgstr "Odwołanie pracy zdalnej oczekuje na decyzję"

#: notifier/receivers.py:834
msgid "One of remote works is pending to cancel."
msgstr ""
"Jeden z wniosków o pracę zdalną oczekuje na decyzję w sprawie odwołania."

