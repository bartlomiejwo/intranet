"zakończenia."

#: notifier/receivers.py:686
msgid "Request to finish remote work earlier accepted"
msgstr "Prośba o wcześniejsze zakończenie pracy zdalnej została zaakceptowana."

#: notifier/receivers.py:687
msgid "Request to finish remote work earlier has been accepted."
msgstr "Prośba o wcześniejsze zakończenie pracy zdalnej została zaakceptowana."

#: notifier/receivers.py:696
msgid "Remote work finished earlier"
msgstr "Praca zdalna zakończona wcześniej"

