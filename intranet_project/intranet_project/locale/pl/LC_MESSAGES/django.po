msgid "One of requests to finish remote work earlier was accepted."
msgstr ""
"Jedna z prósb o wcześniejsze zakończenie pracy zdalnej została zaakceptowana."

#: notifier/receivers.py:704 notifier/receivers.py:714
msgid "Request to finish remote work earlier rejected"
msgstr "Prośba o wcześniejsze zakończenie pracy zdalnej odrzucona"

